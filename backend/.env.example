# AirmonGUI backend — environment variable reference
# Copy this file to .env and adjust values as needed.
# Variables are read at startup from the process environment;
# they are NOT loaded from a .env file automatically — export them
# in your shell or use a launcher script.

# ── Capture storage ───────────────────────────────────────────────────────────
# Absolute path where airodump-ng / aircrack-ng output files are written.
# The directory is created automatically if it does not exist.
AIRMON_GUI_CAPTURE_DIR=/tmp/airmongui

# ── HTTP server ───────────────────────────────────────────────────────────────
# Host and port for the Uvicorn server.
# Bind to 127.0.0.1 (default) to keep the API local-only.
# Change to 0.0.0.0 only on an isolated / trusted network.
API_HOST=127.0.0.1
API_PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed by the browser.
# Add your frontend origin here when deploying the built dist/ assets from
# a different host or port than the API.
CORS_ORIGINS=http://localhost:5173
