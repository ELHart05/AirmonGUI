# AirmonGUI backend — environment variable reference
# Reference for the available variables and their defaults.
# Variables are read at startup from the process environment;
# they are NOT loaded from a .env file automatically — export them
# in your shell or use a launcher script.

# ── Capture storage ───────────────────────────────────────────────────────────
# Absolute path where airodump-ng / aircrack-ng output files are written.
# The directory is created automatically if it does not exist.
AIRMON_GUI_CAPTURE_DIR=/tmp/airmongui

# ── Authentication ──────────────────────────────────────────────────────────--
# A token guards every privileged endpoint. Set it here to pin a fixed value;
# leave it unset and the backend generates one at startup and prints it to the
# console. Paste the token into the web UI when it asks. You must set this
# explicitly before binding API_HOST to anything other than loopback.
# AIRMON_GUI_AUTH_TOKEN=change-me-to-a-long-random-string

# Cap on concurrently running tool jobs (scan/deauth/handshake/crack).
AIRMON_GUI_MAX_ACTIVE_JOBS=8

# Colon-separated directories a cracking wordlist may live in. The capture
# directory is always allowed. A wordlist outside these is refused.
AIRMON_GUI_WORDLIST_DIRS=/usr/share/wordlists:/usr/share/seclists

# ── HTTP server ───────────────────────────────────────────────────────────────
# Host and port for the Uvicorn server.
# Bind to 127.0.0.1 (default) to keep the API local-only.
# Binding to 0.0.0.0 requires AIRMON_GUI_AUTH_TOKEN to be set, or the backend
# refuses to start.
API_HOST=127.0.0.1
API_PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed by the browser.
# Add your frontend origin here when deploying the built dist/ assets from
# a different host or port than the API.
CORS_ORIGINS=http://localhost:5173

# Origins allowed to open the WebSocket terminal. Defaults to CORS_ORIGINS.
# ALLOWED_WS_ORIGINS=http://localhost:5173

# ── Interactive terminal ──────────────────────────────────────────────────────
# The /ws/terminal shell is OFF by default. Set this to 1 to allow it. Even then
# it refuses to open while the backend runs as root unless the break-glass flag
# below is also set. A valid token (and an allowed Origin) is always required.
# AIRMON_GUI_TERMINAL_ENABLED=0
# AIRMON_GUI_ALLOW_TERMINAL_AS_ROOT=0
