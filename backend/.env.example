# AirmonGUI backend — environment variable reference
# Copy this to backend/.env and edit. The backend loads backend/.env at startup,
# so values here take effect without exporting them by hand. A variable already
# exported in your shell still wins over the file. AIRMON_GUI_ENV_FILE selects which
# file to load; set it in the environment (not here) to point at a different path,
# or set it empty to skip loading.

# ── Capture storage ───────────────────────────────────────────────────────────
# Absolute path where airodump-ng / aircrack-ng output files are written.
# Created at mode 0700 if missing. Keep it OFF world-writable /tmp: the backend
# refuses to start if the directory is a symlink or not owned by the running user,
# and captures (which can hold handshakes and recovered keys) are written 0600.
AIRMON_GUI_CAPTURE_DIR=/var/lib/airmongui/captures

# ── Authentication ──────────────────────────────────────────────────────────--
# Auth is on by default. Set this to false to drop the token requirement entirely
# (the web UI then skips the unlock screen). With auth off the privileged API is
# open to anything that can reach it, so the backend refuses to bind off loopback.
# AIRMON_GUI_AUTH_ENABLED=true

# The token that guards every privileged endpoint when auth is enabled. Set it to
# pin a fixed value; leave it unset and the backend generates one at startup and
# prints it to the console. Paste the token into the web UI when it asks. You must
# set this explicitly before binding API_HOST to anything other than loopback.
# AIRMON_GUI_AUTH_TOKEN=change-me-to-a-long-random-string

# Cap on concurrently running tool jobs (scan/deauth/handshake/crack).
AIRMON_GUI_MAX_ACTIVE_JOBS=8

# Colon-separated directories a cracking wordlist may live in. The capture
# directory is always allowed. A wordlist outside these is refused.
AIRMON_GUI_WORDLIST_DIRS=/usr/share/wordlists:/usr/share/seclists

# ── HTTP server ───────────────────────────────────────────────────────────────
# Host and port for the Uvicorn server.
# Bind to 127.0.0.1 (default) to keep the API local-only. Binding off loopback
# needs auth enabled with an explicit AIRMON_GUI_AUTH_TOKEN; with auth disabled the
# backend refuses to start on anything but loopback.
API_HOST=127.0.0.1
API_PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed by the browser.
# Add your frontend origin here when deploying the built dist/ assets from
# a different host or port than the API.
CORS_ORIGINS=http://localhost:5173

# Origins allowed to open the WebSocket terminal. Defaults to CORS_ORIGINS.
# ALLOWED_WS_ORIGINS=http://localhost:5173

# ── Interactive terminal ──────────────────────────────────────────────────────
# The /ws/terminal shell is ON by default and gated by the API token and Origin.
# Set this to 0 to remove the route entirely.
# AIRMON_GUI_TERMINAL_ENABLED=1
#
# ALLOW_TERMINAL_AS_ROOT only matters when auth is DISABLED: it permits an
# unauthenticated root shell (off by default). With auth enabled the token is the
# gate and this flag is ignored.
# AIRMON_GUI_ALLOW_TERMINAL_AS_ROOT=0
